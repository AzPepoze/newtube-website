{
    "name": "backend",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "deploy": "bun run db:migrate:remote && wrangler deploy",
        "dev": "bun run db:migrate:local && wrangler dev",
        "check": "tsc --noEmit",
        "start": "bun run db:migrate:local && wrangler dev",
        "test": "vitest",
        "cf-typegen": "wrangler types",
        "db:generate": "drizzle-kit generate",
        "db:migrate:local": "wrangler d1 migrations apply DB --local",
        "db:migrate:remote": "wrangler d1 migrations apply DB --remote"
    },
    "devDependencies": {
        "@cloudflare/vitest-pool-workers": "^0.8.71",
        "@types/node": "^25.3.3",
        "drizzle-kit": "^0.31.9",
        "typescript": "^5.9.3",
        "vitest": "~3.0.9",
        "wrangler": "^4.69.0"
    },
    "dependencies": {
        "@elysiajs/cors": "^1.4.1",
        "drizzle-orm": "^0.45.1",
        "elysia": "^1.4.27"
    }
}
